# -----------------------------------------------------------------------------
# Newsletter Agent - Environment Variables Template
# Copy this file to .env and fill real values.
# -----------------------------------------------------------------------------

# Data and storage (optional; default is /data)
NEWSLETTER_DATA_DIR=/data

# Source APIs
TAVILY_API_KEY=your_tavily_api_key
# Note: Social signals (Reddit, HuggingFace, HN) are now fetched via Tavily.
# No separate Reddit credentials required.

# LLM provider (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# SMTP delivery (Gmail App Password)
SMTP_USER=your_gmail_address@gmail.com
SMTP_APP_PASS=your_16_char_app_password
SMTP_TO=recipient_email@example.com

# Telegram failure alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id